indicator(
    title: "Triple EMA",
    short_title: "TEMA",
    overlay: true,
    timeframe: "",
    timeframe_gaps: true
);
let length = input.int(9, minval: 1);
let ema1 = ta.ema(close, length);
let ema2 = ta.ema(ema1, length);
let ema3 = ta.ema(ema2, length);
let out = 3 * (ema1 - ema2) + ema3;
plot(out, "TEMA", color: #2962FF);
