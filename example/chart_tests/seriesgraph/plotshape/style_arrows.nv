// 正确结果：4 种箭头形状依次出现（每 10 根柱一种，40 根柱一循环），
// ArrowUp（柱上）、ArrowDown（柱下）、TriangleUp（柱上）、TriangleDown（柱下），形状各异
indicator("Chart Test: plotshape/style_arrows", overlay: true);

let cycle = bar_index % 40;
plot_shape(cycle == 0,  "ArrowUp",     style: Shape.ArrowUp,     location: Location.AboveBar, color: Color.BLUE,   size: Size.Small);
plot_shape(cycle == 10, "ArrowDown",   style: Shape.ArrowDown,   location: Location.BelowBar, color: Color.RED,    size: Size.Small);
plot_shape(cycle == 20, "TriangleUp",  style: Shape.TriangleUp,  location: Location.AboveBar, color: Color.GREEN,  size: Size.Small);
plot_shape(cycle == 30, "TriangleDown",style: Shape.TriangleDown,location: Location.BelowBar, color: Color.ORANGE, size: Size.Small);
