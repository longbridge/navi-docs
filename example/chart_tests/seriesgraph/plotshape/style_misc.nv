// 正确结果：6 种形状依次出现（每 10 根柱一种，60 根柱一循环），
// Circle、Cross、Diamond（柱上）、Flag（柱上）、Square、XCross（柱下），轮廓各异
indicator("Chart Test: plotshape/style_misc", overlay: true);

let cycle = bar_index % 60;
plot_shape(cycle == 0,  "Circle",  style: Shape.Circle,  location: Location.AboveBar, color: Color.BLUE,   size: Size.Normal);
plot_shape(cycle == 10, "Cross",   style: Shape.Cross,   location: Location.AboveBar, color: Color.RED,    size: Size.Normal);
plot_shape(cycle == 20, "Diamond", style: Shape.Diamond, location: Location.AboveBar, color: Color.GREEN,  size: Size.Normal);
plot_shape(cycle == 30, "Flag",    style: Shape.Flag,    location: Location.AboveBar, color: Color.PURPLE, size: Size.Normal);
plot_shape(cycle == 40, "Square",  style: Shape.Square,  location: Location.BelowBar, color: Color.ORANGE, size: Size.Normal);
plot_shape(cycle == 50, "XCross",  style: Shape.XCross,  location: Location.BelowBar, color: Color.TEAL,   size: Size.Normal);
