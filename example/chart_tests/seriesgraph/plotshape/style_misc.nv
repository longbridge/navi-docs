// 正确结果：每 10 根柱出现六种不同几何形状，各形状轮廓明显可区分：
// Circle（圆形）、Cross（+号）、Diamond（菱形）、Flag（旗帜）、Square（方形）、XCross（×号）
indicator("Chart Test: plotshape/style_misc", overlay: true);

let t = bar_index % 10 == 0;
plot_shape(t, "Circle", style: Shape.Circle, location: Location.AboveBar, color: Color.BLUE, size: Size.Small);
plot_shape(t, "Cross", style: Shape.Cross, location: Location.AboveBar, color: Color.RED, size: Size.Small);
plot_shape(t, "Diamond", style: Shape.Diamond, location: Location.AboveBar, color: Color.GREEN, size: Size.Small);
plot_shape(t, "Flag", style: Shape.Flag, location: Location.AboveBar, color: Color.PURPLE, size: Size.Small);
plot_shape(t, "Square", style: Shape.Square, location: Location.BelowBar, color: Color.ORANGE, size: Size.Small);
plot_shape(t, "XCross", style: Shape.XCross, location: Location.BelowBar, color: Color.TEAL, size: Size.Small);
