// 正确结果：5 种尺寸依次出现（每 10 根柱一种，50 根柱一循环），
// Tiny→Small→Normal→Large→Huge，大小差异肉眼清晰可辨
indicator("Chart Test: plotchar/size", overlay: true);

let cycle = bar_index % 50;
plot_char(cycle == 0,  "Tiny",   char: "★", location: Location.AboveBar, color: Color.BLUE,   size: Size.Tiny);
plot_char(cycle == 10, "Small",  char: "★", location: Location.AboveBar, color: Color.RED,    size: Size.Small);
plot_char(cycle == 20, "Normal", char: "★", location: Location.AboveBar, color: Color.GREEN,  size: Size.Normal);
plot_char(cycle == 30, "Large",  char: "★", location: Location.AboveBar, color: Color.PURPLE, size: Size.Large);
plot_char(cycle == 40, "Huge",   char: "★", location: Location.AboveBar, color: Color.ORANGE, size: Size.Huge);
