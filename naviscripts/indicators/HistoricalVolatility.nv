indicator(
    title: "Historical Volatility",
    shorttitle: "HV",
    format: Format.Price,
    precision: 2,
    timeframe: "",
    timeframe_gaps: true
);
let length = input.int(10, minval: 1);
let annual = 365;
let per = timeframe.isintraday or timeframe.isdaily and timeframe.multiplier == 1 ? 1 : 7;
let hv = 100 * ta.stdev(math.log(close / close[1]), length) * math.sqrt(
    annual / per
);
plot(hv, "HV", color: #2962FF);
