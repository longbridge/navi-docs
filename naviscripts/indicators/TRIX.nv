indicator(
    title: "TRIX",
    short_title: "TRIX",
    format: Format.Price,
    precision: 2,
    timeframe: "",
    timeframe_gaps: true
);
let length = input.int(18, minval: 1);
let out = 10000 * ta.change(
    ta.ema(ta.ema(ta.ema(math.log(close), length), length), length)
);
plot(out, color: #F44336, title: "TRIX");
hline(0, color: #787B86, title: "Zero");
