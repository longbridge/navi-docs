indicator(
    "Pivot Points Standard",
    "Pivots",
    overlay: true,
    max_lines_count: 500,
    max_labels_count: 500
);

let pivotTypeInput = input.string(
    title: "Type",
    defval: "Traditional",
    options: [
        "Traditional",
        "Fibonacci",
        "Woodie",
        "Classic",
        "DM",
        "Camarilla"
    ]
);
let pivotAnchorInput = input.string(
    title: "Pivots Timeframe",
    defval: "Auto",
    options: [
        "Auto",
        "Daily",
        "Weekly",
        "Monthly",
        "Quarterly",
        "Yearly",
        "Biyearly",
        "Triyearly",
        "Quinquennially",
        "Decennially"
    ]
);
let maxHistoricalPivotsInput = input.int(
    title: "Number of Pivots Back",
    defval: 15,
    minval: 1,
    maxval: 200,
    display: PlotDisplay.NONE
);
let isDailyBasedInput = input.bool(
    title: "Use Daily-based Values",
    defval: true,
    display: PlotDisplay.NONE,
    tooltip: "When this option is unchecked, Pivot Points will use intraday data while calculating on intraday charts. If Extended Hours are displayed on the chart, they will be taken into account during the pivot level calculation. If intraday OHLC values are different from daily-based values (normal for stocks), the pivot levels will also differ."
);
let showLabelsInput = input.bool(
    title: "Show Labels",
    defval: true,
    group: "labels",
    display: PlotDisplay.NONE
);
let showPricesInput = input.bool(
    title: "Show Prices",
    defval: true,
    group: "labels",
    display: PlotDisplay.NONE
);
let positionLabelsInput = input.string(
    "Left",
    "Labels Position",
    options: ["Left", "Right"],
    group: "labels",
    display: PlotDisplay.NONE,
    active: showLabelsInput or showPricesInput
);
let linewidthInput = input.int(
    title: "line Width",
    defval: 1,
    minval: 1,
    maxval: 100,
    group: "levels",
    display: PlotDisplay.NONE
);

let DEFAULT_COLOR = #FB8C00;

let showLevel2and3 = pivotTypeInput != "DM";
let showLevel4 = pivotTypeInput != "DM" and pivotTypeInput != "Fibonacci";
let showLevel5 = pivotTypeInput == "Traditional" or pivotTypeInput == "Camarilla";

let pColorInput = input.color(
    DEFAULT_COLOR,
    "PтАП  тАП  тАП",
    inline: "P",
    group: "levels",
    display: PlotDisplay.NONE
);
let pShowInput = input.bool(
    true,
    "",
    inline: "P",
    group: "levels",
    display: PlotDisplay.NONE
);
let s1ColorInput = input.color(
    DEFAULT_COLOR,
    "S1",
    inline: "S1/R1",
    group: "levels",
    display: PlotDisplay.NONE
);
let s1ShowInput = input.bool(
    true,
    "",
    inline: "S1/R1",
    group: "levels",
    display: PlotDisplay.NONE
);
let r1ColorInput = input.color(
    DEFAULT_COLOR,
    "тАП  тАП  тАП  тАП  тАП  тАП  тАП  тАПR1",
    inline: "S1/R1",
    group: "levels",
    display: PlotDisplay.NONE
);
let r1ShowInput = input.bool(
    true,
    "",
    inline: "S1/R1",
    group: "levels",
    display: PlotDisplay.NONE
);
let s2ColorInput = input.color(
    DEFAULT_COLOR,
    "S2",
    inline: "S2/R2",
    group: "levels",
    display: PlotDisplay.NONE,
    active: showLevel2and3
);
let s2ShowInput = input.bool(
    true,
    "",
    inline: "S2/R2",
    group: "levels",
    display: PlotDisplay.NONE,
    active: showLevel2and3
);
let r2ColorInput = input.color(
    DEFAULT_COLOR,
    "тАП  тАП  тАП  тАП  тАП  тАП  тАП  тАПR2",
    inline: "S2/R2",
    group: "levels",
    display: PlotDisplay.NONE,
    active: showLevel2and3
);
let r2ShowInput = input.bool(
    true,
