    true,
    "",
    inline: "S4/R4",
    group: "levels",
    display: PlotDisplay.NONE,
    active: showLevel4
);
let r4ColorInput = input.color(
    DEFAULT_COLOR,
    "тАП  тАП  тАП  тАП  тАП  тАП  тАП  тАПR4",
    inline: "S4/R4",
    group: "levels",
    display: PlotDisplay.NONE,
    active: showLevel4
);
let r4ShowInput = input.bool(
    true,
    "",
    inline: "S4/R4",
    group: "levels",
    display: PlotDisplay.NONE,
    active: showLevel4
);
let s5ColorInput = input.color(
    DEFAULT_COLOR,
    "S5",
    inline: "S5/R5",
    group: "levels",
    display: PlotDisplay.NONE,
    active: showLevel5
);
let s5ShowInput = input.bool(
    true,
    "",
    inline: "S5/R5",
    group: "levels",
    display: PlotDisplay.NONE,
    active: showLevel5
);
let r5ColorInput = input.color(
    DEFAULT_COLOR,
    "тАП  тАП  тАП  тАП  тАП  тАП  тАП  тАПR5",
    inline: "S5/R5",
    group: "levels",
    display: PlotDisplay.NONE,
    active: showLevel5
);
