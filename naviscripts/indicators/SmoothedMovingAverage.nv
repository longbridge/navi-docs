indicator(
    title: "Smoothed Moving Average",
    shorttitle: "SMMA",
    overlay: true,
    timeframe: "",
    timeframe_gaps: true
);
let len = input.int(7, minval: 1, title: "Length");
let src = input(close, title: "Source");
let smma = 0.0;
smma = na(smma[1]) ? ta.sma(src, len) : (smma[1] * (len - 1) + src) / len;
plot(smma, "SMMA", color: #673AB7);
