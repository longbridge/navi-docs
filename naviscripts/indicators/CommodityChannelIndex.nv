indicator(
    title: "Commodity Channel Index",
    short_title: "CCI",
    format: Format.Price,
    precision: 2,
    timeframe: "",
    timeframe_gaps: true
);
let length = input.int(20, minval: 1);
let src = input(hlc3, title: "Source");
let ma = ta.sma(src, length);
let cci = (src - ma) / (0.015 * ta.dev(src, length));
plot(cci, "CCI", color: #2962FF);
let band1 = hline(
    100,
    "Upper Band",
    color: #787B86,
    line_style: HLineStyle.Dashed
);
hline(0, "Middle Band", color: Color.new(#787B86, 50));
let band0 = hline(
    -100,
    "Lower Band",
    color: #787B86,
    line_style: HLineStyle.Dashed
);
fill(band1, band0, color: Color.rgb(33, 150, 243, 90), title: "Background");

let GRP = "Smoothing";
let TT_BB = "Only applies when 'SMA + Bollinger Bands' is selected. Determines the distance between the SMA and the bands.";
let maTypeInput = input.string(
    "SMA",
    "Type",
    options: [
        "None",
        "SMA",
        "SMA + Bollinger Bands",
        "EMA",
        "SMMA (RMA)",
        "WMA",
        "VWMA"
    ],
    group: GRP,
    display: PlotDisplay.NONE
);
var isBB = maTypeInput == "SMA + Bollinger Bands";
let maLengthInput = input.int(
    14,
    "Length",
    group: GRP,
    display: PlotDisplay.NONE,
    active: maTypeInput != "None"
);
let bbMultInput = input.float(
    2.0,
    "BB StdDev",
    minval: 0.001,
    maxval: 50,
    step: 0.5,
    tooltip: TT_BB,
    group: GRP,
    display: PlotDisplay.NONE,
    active: isBB
);
var enableMA = maTypeInput != "None";

fn ma(source, length, MAtype) {
    switch MAtype {
        "SMA" => ta.sma(source, length),
        "SMA + Bollinger Bands" => ta.sma(source, length),
        "EMA" => ta.ema(source, length),
        "SMMA (RMA)" => ta.rma(source, length),
        "WMA" => ta.wma(source, length),
        "VWMA" => ta.vwma(source, length),
    }
}

let smoothingMA = enableMA ? ma(cci, maLengthInput, maTypeInput) : na;
let smoothingStDev = isBB ? ta.stdev(cci, maLengthInput) * bbMultInput : na;
plot(
    smoothingMA,
    "CCI-based MA",
    color: Color.YELLOW,
    display: enableMA ? PlotDisplay.ALL : PlotDisplay.NONE,
    editable: enableMA
);
let bbUpperBand = plot(
    smoothingMA + smoothingStDev,
    title: "Upper Bollinger Band",
    color: Color.GREEN,
    display: isBB ? PlotDisplay.ALL : PlotDisplay.NONE,
    editable: isBB
);
let bbLowerBand = plot(
    smoothingMA - smoothingStDev,
    title: "Lower Bollinger Band",
    color: Color.GREEN,
    display: isBB ? PlotDisplay.ALL : PlotDisplay.NONE,
    editable: isBB
);
fill(
    bbUpperBand,
    bbLowerBand,
    color: isBB ? Color.new(Color.GREEN, 90) : na,
    title: "Bollinger Bands Background Fill",
    display: isBB ? PlotDisplay.ALL : PlotDisplay.NONE,
    editable: isBB
);
