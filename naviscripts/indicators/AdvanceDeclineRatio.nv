indicator(
    title: "Advance Decline Ratio",
    short_title: "ADR",
    format: Format.Price,
    precision: 2
);
fn ratio(t1, t2, source) {
    request.security(t1, timeframe.period, source) / request.security(
        t2,
        timeframe.period,
        source
    );
}
plot(ratio("USI:ADVN.NY", "USI:DECL.NY", close));
