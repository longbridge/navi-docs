indicator(
    title: "Klinger Oscillator",
    format: Format.Volume,
    timeframe: "",
    timeframe_gaps: true
);
var cumVol = 0.;
cumVol += nz(volume);
if bar_state.is_last and cumVol == 0 {
    runtime.error("No volume is provided by the data vendor.");
}
let sv = ta.change(hlc3) >= 0 ? volume : -volume;
let kvo = ta.ema(sv, 34) - ta.ema(sv, 55);
let sig = ta.ema(kvo, 13);
plot(kvo, color: #2962FF, title: "Klinger Oscillator");
plot(sig, color: #43A047, title: "Signal");
